---
import { PLATFORMS } from "../config";
---

<section class="hero" id="top" data-parallax-scope>
  <div class="wrap hero__inner">
    <div class="hero__copy">
      <p class="eyebrow" data-reveal><span class="tick"></span>Local-first HR intelligence</p>
      <h1 class="hero__title" data-reveal>
        HR judgment,<br />on <span class="accent">your</span> machine.
      </h1>
      <p class="lead hero__lead" data-reveal>
        Cadre reads resumes, drafts interview questions, builds your forms, and
        pressure-tests a termination — entirely on your computer. Nothing leaves
        the building.
      </p>
      <div class="hero__cta" data-reveal>
        <a href="#download" class="btn btn--accent">Get early access</a>
        <a href="#how" class="btn btn--ghost">See how it works</a>
      </div>
      <p class="hero__meta" data-reveal>
        <span class="dot"></span>Coming soon for {PLATFORMS}
      </p>
    </div>

    <!-- floating, parallaxed app mock inside a frame -->
    <div class="hero__stage" aria-hidden="true">
      <div class="mock frame" data-parallax="-0.12">
        <div class="mock__bar">
          <span></span><span></span><span></span>
          <em>Cadre — Senior Backend Engineer</em>
        </div>
        <div class="mock__body">
          <div class="mock__side">
            <span class="on">Gap analysis</span>
            <span>Interview prep</span>
            <span>Compare</span>
            <span>Forms</span>
            <span>Termination</span>
          </div>
          <div class="mock__main">
            <p class="mock__kicker">GAPS TO EXPLORE · NO SCORE</p>
            <div class="mock__row"><i class="lvl crit"></i>No production Kubernetes experience</div>
            <div class="mock__row"><i class="lvl note"></i>Led teams, but never owned hiring</div>
            <div class="mock__row"><i class="lvl note"></i>Payments domain is adjacent, not direct</div>
            <div class="mock__row"><i class="lvl min"></i>Open-source cadence has slowed since 2023</div>
            <div class="mock__redacted">
              <span></span><span></span><span></span>
            </div>
          </div>
        </div>
      </div>
      <div class="mock__chip frame" data-parallax="0.32">
        <span class="dot dot--accent"></span>On-device · 0 bytes uploaded
      </div>
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span>Scroll</span>
    <i></i>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: clamp(84px, 10vh, 116px);
    padding-bottom: clamp(3rem, 6vh, 5rem);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    width: 100%;
  }
  .hero__title {
    font-size: var(--step-5);
    margin-top: 1.1rem;
    letter-spacing: -0.035em;
  }
  .hero__lead {
    margin-top: 1.4rem;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.9rem;
  }
  .hero__meta {
    display: flex;
    align-items: center;
    gap: 0.6em;
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-faint);
    letter-spacing: 0.05em;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--ink-faint);
    display: inline-block;
  }
  .dot--accent {
    background: var(--accent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 60%, transparent);
    animation: pulse 2.4s ease-out infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 55%, transparent); }
    70% { box-shadow: 0 0 0 9px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  /* --- the app mock --- */
  .hero__stage {
    position: relative;
    justify-self: end;
    width: 100%;
    max-width: 540px;
  }
  .mock {
    background: var(--white);
    box-shadow: 0 40px 80px -40px rgba(23, 22, 15, 0.4);
  }
  .mock__bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--line);
  }
  .mock__bar span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1px solid var(--line-strong);
  }
  .mock__bar em {
    margin-left: auto;
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.72rem;
    color: var(--ink-faint);
  }
  .mock__body {
    display: grid;
    grid-template-columns: 0.8fr 1.6fr;
    min-height: 320px;
  }
  .mock__side {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 1rem 0.8rem;
    border-right: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
  }
  .mock__side span {
    padding: 0.4rem 0.5rem;
    border-radius: var(--radius);
  }
  .mock__side .on {
    background: var(--paper-2);
    color: var(--ink);
  }
  .mock__main {
    padding: 1.1rem 1.1rem 1.3rem;
  }
  .mock__kicker {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    color: var(--ink-faint);
    margin-bottom: 0.9rem;
  }
  .mock__row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    padding: 0.55rem 0;
    border-top: 1px solid var(--line-soft);
  }
  .lvl {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: 1px;
  }
  .lvl.crit { background: var(--accent); }
  .lvl.note { background: var(--ink-soft); }
  .lvl.min { background: var(--ink-faint); }
  .mock__redacted {
    display: flex;
    gap: 0.4rem;
    margin-top: 1rem;
  }
  .mock__redacted span {
    height: 9px;
    background: var(--ink);
    border-radius: 1px;
  }
  .mock__redacted span:nth-child(1) { width: 34%; }
  .mock__redacted span:nth-child(2) { width: 20%; }
  .mock__redacted span:nth-child(3) { width: 26%; }

  .mock__chip {
    position: absolute;
    left: -1.5rem;
    bottom: -1.3rem;
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    padding: 0.7em 1em;
    background: var(--white);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink);
    box-shadow: 0 24px 50px -30px rgba(23, 22, 15, 0.5);
  }

  .hero__scroll {
    position: absolute;
    left: var(--gutter);
    bottom: clamp(1.2rem, 4vh, 2.4rem);
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .hero__scroll i {
    width: 38px;
    height: 1px;
    background: var(--line-strong);
    position: relative;
    overflow: hidden;
  }
  .hero__scroll i::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform: translateX(-100%);
    animation: track 2.6s ease-in-out infinite;
  }
  @keyframes track {
    0% { transform: translateX(-100%); }
    50% { transform: translateX(0); }
    100% { transform: translateX(100%); }
  }

  @media (max-width: 920px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__stage { max-width: 460px; margin-top: 1rem; }
    .hero__scroll { display: none; }
  }
</style>
