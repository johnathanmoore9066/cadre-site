# Copy this file to .env for local development. The real .env is gitignored —
# never commit secrets. In production these go in Vercel:
# Project → Settings → Environment Variables.

# Resend API key. Create one at https://resend.com/api-keys
RESEND_API_KEY=

# Where waitlist signups are emailed. Falls back to the address baked into
# src/pages/api/waitlist.ts if left unset.
WAITLIST_TO=johnathanmoore@elementfusion.org

# Sender address. MUST be on a domain you've verified in Resend.
# Leave blank for first tests — the code falls back to onboarding@resend.dev,
# which only delivers to your Resend account email. After verifying
# cadresource.org at https://resend.com/domains, set something like:
# WAITLIST_FROM=Cadre <waitlist@cadresource.org>
WAITLIST_FROM=
